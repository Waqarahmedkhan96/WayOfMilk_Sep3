@page "/transfer-records"
@rendermode InteractiveServer

@using ApiContracts.TransferRecords
@inject ITransferRecordService TransferRecordService
@inject NavigationManager Nav

<PageTitle>Transfer Records</PageTitle>

<h1>Transfer Records</h1>

<button class="btn btn-primary mb-3"
        @onclick="@(() => Nav.NavigateTo("/transfer-records/create"))">
    Add new transfer record
</button>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (!string.IsNullOrEmpty(error))
{
    <p style="color:red">@error</p>
}
else if (transferRecords is null || transferRecords.Count == 0)
{
    <p>No transfer records yet.</p>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>Id</th>
            <th>Cow</th>
            <th>Move Date</th>
            <th>From Dept</th>
            <th>To Dept</th>
            <th>Requested By</th>
            <th>Approved By</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var record in transferRecords)
        {
            <tr>
                <td>@record.Id</td>
                <td>@record.CowId</td>
                <td>@record.MovedAt</td>
                <td>@record.FromDepartmentId</td>
                <td>@record.ToDepartmentId</td>
                <td>@record.RequestedByUserId</td>
                <td>@record.ApprovedByVetUserId</td>

                <td>
                    <button class="btn btn-sm btn-danger"
                            @onclick="() => DeleteAsync(record.Id)">
                        Delete
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
@code {
    private bool isLoading = true;
    private string? error;
    private ICollection<TransferRecordDto>? transferRecords;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            transferRecords = await TransferRecordService.GetAllAsync();
        }
        catch (Exception e)
        {
            error = e.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteAsync(long id)
    {
        error = null;
        try
        {
            await TransferRecordService.DeleteAsync(id);
            transferRecords = await TransferRecordService.GetAllAsync();
        }
        catch (Exception e)
        {
            error = e.Message;
        }
    }
}
