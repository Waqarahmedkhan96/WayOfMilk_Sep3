@page "/transfer-records/create"
@rendermode InteractiveServer

@using ApiContracts.TransferRecords
@using ApiContracts.Departments
@inject ITransferRecordService TransferRecordService
@inject NavigationManager Nav

<PageTitle>Add Transfer Record</PageTitle>

<h1>Add new transfer record</h1>

<div class="mb-3">
    <label class="form-label">Cow Id</label>
    <InputNumber @bind-Value="cowId" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">Move Date</label>
    <InputDate @bind-Value="moveDate" TValue="DateOnly" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">From Department</label>
    <InputSelect @bind-Value="fromDept" class="form-control">
        @foreach (var dept in Enum.GetValues<DepartmentType>())
        {
            <option value="@dept">@dept</option>
        }
    </InputSelect>
</div>

<div class="mb-3">
    <label class="form-label">To Department</label>
    <InputSelect @bind-Value="toDept" class="form-control">
        @foreach (var dept in Enum.GetValues<DepartmentType>())
        {
            <option value="@dept">@dept</option>
        }
    </InputSelect>
</div>

<div class="mb-3">
    <label class="form-label">Requested By Employee Id</label>
    <InputNumber @bind-Value="requestedByUserId" class="form-control" />
</div>

@if (!string.IsNullOrEmpty(error))
{
    <p style="color:red">@error</p>
}

<button class="btn btn-success" @onclick="CreateAsync">Save</button>
<button class="btn btn-secondary ms-2" @onclick="@(() => Nav.NavigateTo("/transfer-records"))">
    Cancel
</button>

@code {
    private long cowId;
    private DateOnly moveDate = DateOnly.FromDateTime(DateTime.Today);
    private DepartmentType fromDept = DepartmentType.Milking;
    private DepartmentType toDept = DepartmentType.Resting;
    private long requestedByUserId;
    private string? error;

    private async Task CreateAsync()
    {
        error = null;
        try
        {
            var dto = new CreateTransferRecordDto
            {
                CowId = cowId,
                MovedAt = moveDate.ToDateTime(TimeOnly.MinValue),
                FromDepartmentId = (long)fromDept,
                ToDepartmentId = (long)toDept,
                RequestedByUserId = requestedByUserId
            };

            await TransferRecordService.CreateAsync(dto);
            Nav.NavigateTo("/transfer-records");
        }
        catch (Exception e)
        {
            error = e.Message;
        }
    }
}
